# ─── DATABASE (Supabase) ───────────────────────────────────────────────────────
# Ambil dari: Supabase Dashboard → Project Settings → Database → Connection string
# Gunakan format "URI" lalu ganti [YOUR-PASSWORD] dengan password database kamu
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_at_least_32_characters_long

# ─── EXTERNAL APIs ────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
OPENWEATHER_API_KEY=your_openweather_api_key_here

# ─── TELEGRAM BOT ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ─── SERVER ───────────────────────────────────────────────────────────────────
PORT=5001
NODE_ENV=production

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Pisahkan beberapa origin dengan koma
ALLOWED_ORIGINS=https://your-app.netlify.app,http://localhost:5173
